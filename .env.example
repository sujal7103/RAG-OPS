# Local development example only.
# Do not publish a deployment that uses RAG_OPS_AUTH_MODE=dev.
OPENAI_API_KEY=
COHERE_API_KEY=
RAG_OPS_CACHE_DIR=.rag_ops_cache
RAG_OPS_RUNS_DIR=.rag_ops_runs
RAG_OPS_API_BASE_URL=
RAG_OPS_CORS_ALLOWED_ORIGINS=
RAG_OPS_UI_API_POLL_INTERVAL_SECONDS=1.0
RAG_OPS_DATABASE_URL=sqlite:///./.rag_ops/rag_ops.db
RAG_OPS_REDIS_ENABLED=false
RAG_OPS_REDIS_URL=redis://localhost:6379/0
RAG_OPS_QUEUE_BACKEND=thread
# Local-only auth mode for development. Use oidc or jwks for shared/staging/prod deployments.
RAG_OPS_AUTH_MODE=dev
RAG_OPS_AUTH_OIDC_DISCOVERY_URL=
RAG_OPS_AUTH_OIDC_JWKS_URL=
RAG_OPS_AUTH_JWT_ISSUER=
RAG_OPS_AUTH_JWT_AUDIENCE=
RAG_OPS_DEV_DEFAULT_USER_EMAIL=owner@ragops.local
RAG_OPS_DEV_DEFAULT_USER_NAME=RAG-OPS Owner
RAG_OPS_DEV_DEFAULT_USER_ROLE=workspace_owner
RAG_OPS_CREDENTIAL_KEY=change-me-long-random-string
RAG_OPS_CREDENTIAL_ACTIVE_KEY_ID=v1
RAG_OPS_CREDENTIAL_KEYS_JSON=
RAG_OPS_METRICS_ENABLED=false
RAG_OPS_WORKER_METRICS_PORT=9101
RAG_OPS_OBJECT_STORE_ENABLED=false
RAG_OPS_OBJECT_STORE_ENDPOINT=http://localhost:9000
RAG_OPS_OBJECT_STORE_BUCKET=rag-ops
RAG_OPS_OBJECT_STORE_ACCESS_KEY=
RAG_OPS_OBJECT_STORE_SECRET_KEY=
RAG_OPS_DEAD_LETTER_DIR=.rag_ops_dead_letters
RAG_OPS_POSTGRES_PASSWORD=change-me
RAG_OPS_MINIO_ROOT_USER=change-me
RAG_OPS_MINIO_ROOT_PASSWORD=change-me
RAG_OPS_GRAFANA_ADMIN_PASSWORD=change-me
