# Shared deployment example.
# Replace every placeholder and keep admin, metrics, and data services behind trusted network boundaries.
RAG_OPS_ENV=staging
RAG_OPS_API_BASE_URL=http://api:8000
RAG_OPS_CORS_ALLOWED_ORIGINS=https://ragops.example.com
RAG_OPS_DATABASE_URL=postgresql+psycopg://postgres:${RAG_OPS_POSTGRES_PASSWORD}@postgres:5432/rag_ops
RAG_OPS_REDIS_ENABLED=true
RAG_OPS_REDIS_URL=redis://redis:6379/0
RAG_OPS_QUEUE_BACKEND=dramatiq
RAG_OPS_AUTH_MODE=oidc
RAG_OPS_AUTH_OIDC_DISCOVERY_URL=https://your-idp/.well-known/openid-configuration
RAG_OPS_AUTH_JWT_ISSUER=https://your-idp/
RAG_OPS_AUTH_JWT_AUDIENCE=rag-ops
RAG_OPS_CREDENTIAL_ACTIVE_KEY_ID=v1
RAG_OPS_CREDENTIAL_KEYS_JSON={"v1":"replace-with-32-byte-key"}
RAG_OPS_METRICS_ENABLED=true
RAG_OPS_OBJECT_STORE_ENABLED=true
RAG_OPS_OBJECT_STORE_ENDPOINT=http://minio:9000
RAG_OPS_OBJECT_STORE_BUCKET=rag-ops
RAG_OPS_OBJECT_STORE_ACCESS_KEY=${RAG_OPS_MINIO_ROOT_USER}
RAG_OPS_OBJECT_STORE_SECRET_KEY=${RAG_OPS_MINIO_ROOT_PASSWORD}
RAG_OPS_POSTGRES_PASSWORD=replace-me
RAG_OPS_MINIO_ROOT_USER=replace-me
RAG_OPS_MINIO_ROOT_PASSWORD=replace-me
RAG_OPS_GRAFANA_ADMIN_PASSWORD=replace-me
